# Copy this file to .env.local. Never commit the real RapidAPI key.
PAGECORDER_API_KEY=replace_with_your_rapidapi_key
PAGECORDER_API_HOST=pagecorder.p.rapidapi.com

# Public URL of the deployed page or hosted ZIP archive to record.
PAGECORDER_SOURCE_URL=https://replace-with-public-page-or-zip-url

# Target recording settings.
PAGECORDER_WIDTH=1280
PAGECORDER_HEIGHT=720
PAGECORDER_DURATION_SECONDS=20
